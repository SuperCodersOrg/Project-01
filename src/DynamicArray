#pragma once

#include <iostream>
#include <cstdlib>
#include <new>

template <typename T>
class DynamicArray {
private:
    int size_;
    int capacity_;
    T *data;

    void destroyElements()
    {
        for(int i=0;i<size_;i++)
        {
            (data+i)->~T();
        }
    }

public:
    //constructor
    DynamicArray()
    {
        size_=0;
        capacity_=0;
        data=nullptr;
    }
    
    //capacity constructor
    DynamicArray(int cap)
    {
        size_=0;
        capacity_=cap;
        if(capacity_>0)
        {
            data = static_cast<T*>(malloc(sizeof(T)*capacity_));
        }
        else
        {
            data=nullptr;
        }
    }

    //destructor
    ~DynamicArray()
    {
        destroyElements();
        free(data);
        data=nullptr;
        size_=0;
        capacity_=0;
    }
};

